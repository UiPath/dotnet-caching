{
  // Reference-only file. Lists every binding-visible Caching option with shipped defaults.
  // Not loaded by the sample at runtime. See docs/reference/settings.md for the readable index.
  "Caching": {
    // ---- Core (UiPath.Caching.CacheOptions) ----
    // Enabled: master on/off switch
    "Enabled": true,
    // TelemetryEnabled: gate the ICachingTelemetryProvider seam
    "TelemetryEnabled": true,
    // BroadcastEnabled: gate the ITopicFactory wiring
    "BroadcastEnabled": true,
    // ShardKeyEnabled: enable for Redis Cluster with multiple shards
    "ShardKeyEnabled": false,
    // AuditEnabled: log writes above LargeValueThreshold
    "AuditEnabled": true,
    // DefaultCache: KnownCacheProviderNames: InMemory | Redis | InMemoryRedis
    "DefaultCache": "InMemoryRedis",
    // DefaultTopic: KnownTopicNames: RedisStreams | RedisPubSub
    "DefaultTopic": "RedisStreams",
    // SourceUri: machine/pod identity for cross-node sync events; defaults to urn:<hostname>
    "SourceUri": "urn:machine1",
    // Separator: key segment separator character
    "Separator": ":",
    // AppShortName: REQUIRED in practice — apps throw on missing/blank
    "AppShortName": "app",
    // LargeValueThreshold: bytes; writes above this are logged when AuditEnabled
    "LargeValueThreshold": 20000,
    // ConnectionMonitorEnabled: health-check Redis connection app-wide
    "ConnectionMonitorEnabled": false,
    // LocalLockPoolSize: semaphore pool size for default local lock (allocation hint, not a hard cap)
    "LocalLockPoolSize": 100,
    // LocalLockPoolInitialFill: semaphores pre-allocated at startup; must be in [0, LocalLockPoolSize]
    "LocalLockPoolInitialFill": 10,
    // DistributedLockPollInterval: initial wait between distributed-lock acquire retries; doubles per attempt up to max
    "DistributedLockPollInterval": "0:00:00.050",
    // DistributedLockMaxPollInterval: upper bound for exponential-backoff retry interval
    "DistributedLockMaxPollInterval": "0:00:00.500",
    // Default factories (ICacheFactory, ICachePolicyFactory): swap code-side via builder.UseCacheFactory<T>() / builder.UseCachePolicyFactory<T>() on the ICachingBuilder inside AddCaching(...). Not bindable from JSON — ConfigurationBinder has no string → Type converter.

    // ---- Connections.Redis (UiPath.Caching.Redis.RedisConnectionOptions) ----
    "Connections": {
      "Redis": {
        // ConnectionString: REQUIRED — StackExchange.Redis connection string
        "ConnectionString": "localhost:6379",
        // ConnectionStringExtraParams: appended to ConnectionString; useful for Azure Redis extra params
        "ConnectionStringExtraParams": null,
        // BackOffMilliseconds: ms to wait before reconnecting after a connection failure
        "BackOffMilliseconds": 1000,
        // HeartbeatConsistencyChecks: null = StackExchange.Redis default; true enables heartbeat consistency checks
        "HeartbeatConsistencyChecks": null,
        // HeartbeatInterval: null = StackExchange.Redis default; TimeSpan override for heartbeat period
        "HeartbeatInterval": null,
        // ProfilerFeatureFlagKey: feature-flag key consulted before enabling profiler
        "ProfilerFeatureFlagKey": "RedisProfiler.Enabled",
        // PlannedMaintenanceEnabled: tolerate planned-maintenance disconnects gracefully
        "PlannedMaintenanceEnabled": true,
        // LogConnectionFailedEvents: log ConnectionFailed events from the multiplexer
        "LogConnectionFailedEvents": true,
        // LogConnectionRestoredEvents: log ConnectionRestored events from the multiplexer
        "LogConnectionRestoredEvents": true,
        // EnableHangDetection: detect hung write/read channels and log warnings
        "EnableHangDetection": true,
        // LastWriteIntervalThresholdMilliseconds: ms since last write before hang is declared
        "LastWriteIntervalThresholdMilliseconds": 15000,
        // LastReadIntervalThresholdMilliseconds: ms since last read before hang is declared
        "LastReadIntervalThresholdMilliseconds": 15000,
        // DefaultVersion: Redis server version hint for StackExchange.Redis
        "DefaultVersion": "6.0",
        // HangDetectionDueTime: delay before first hang-detection check; null = 30s (library default)
        "HangDetectionDueTime": null,
        // HangDetectionPeriod: null = use library default; period between hang-detection checks
        "HangDetectionPeriod": null,
        // FailFastBacklogPolicy: null = library default; true = fail immediately when backlog is full
        "FailFastBacklogPolicy": null,
        // ThreadPoolSocketManager: null = library default; true = use thread-pool socket manager
        "ThreadPoolSocketManager": null,
        // ProfilerEnabled: enable StackExchange.Redis command profiler
        "ProfilerEnabled": false,
        // ProfilerHasDefaultSession: start a default profiling session at startup
        "ProfilerHasDefaultSession": true,
        // ProfilerFlushInterval: how often to flush profiling data
        "ProfilerFlushInterval": "0:00:01",
        // ProfilerSessionMaxLifespan: max lifetime of a profiling session before auto-close
        "ProfilerSessionMaxLifespan": "0:01:00",
        // ProfilerSessionMaxChecks: max commands captured per profiling session
        "ProfilerSessionMaxChecks": 100,
        // ProfilerTrackMetricEnabled: emit profiler metrics via telemetry
        "ProfilerTrackMetricEnabled": true,
        // ConnectionFactory / ProfilingSessionFactory / Clock: set in code; see how-to/telemetry-and-strategies.md
        // ConnectionMultiplexerFactoryType: assembly-qualified type name of IConnectionMultiplexer factory; null = built-in
        "ConnectionMultiplexerFactoryType": null,
        // AbortOnConnectFail: false = retry in background; true = throw on first connect failure
        "AbortOnConnectFail": false
      }
    },

    // ---- Broadcast.RedisStreams (UiPath.Caching.Broadcast.Redis.RedisStreamsTopicOptions) ----
    "Broadcast": {
      "RedisStreams": {
        // Enabled: enable/disable the Redis Streams provider app-wide (per-topic override ignored)
        "Enabled": true,
        // MaxLength: max entries in a stream before trimming (MAXLEN ~); null = unlimited
        "MaxLength": 32768,
        // Limit: max entries returned per XREAD call
        "Limit": 1024,
        // PollBatchSize: max entries fetched per poll cycle
        "PollBatchSize": 4096,
        // FieldName: stream entry field name used for the serialized event payload
        "FieldName": "event",
        // PollInterval: time between poll cycles when no notify signal is received
        "PollInterval": "0:00:00.250",
        // RedisStreamKeyStrategy: set in code; see how-to/telemetry-and-strategies.md
        // ConsumerCapacity: bounded-channel capacity for in-process event delivery; -1 for unbounded
        "ConsumerCapacity": 2048,
        // FullMode: BoundedChannelFullMode when channel is full: Wait | DropNewest | DropOldest | DropWrite
        "FullMode": "Wait",
        // SlowObserverThreshold: log warning when an observer takes longer than this to process an event
        "SlowObserverThreshold": "0:00:00.250",
        // ConnectionMonitorEnabled: null = inherit from CacheOptions.ConnectionMonitorEnabled
        "ConnectionMonitorEnabled": null,
        // TrackStatistics: emit stream-level statistics via telemetry
        "TrackStatistics": false,
        // MaintainerEnabled: run background health maintainer for streams
        "MaintainerEnabled": true,
        // MaintainerCheckInterval: how often the maintainer checks stream health
        "MaintainerCheckInterval": "0:30:00",
        // MaintainerTrimInterval: how often the maintainer trims old entries; must be > InMemoryRedis.LocalMaxExpiration to avoid trimming entries still live in L1
        "MaintainerTrimInterval": "1:00:00",
        // MaintainerQuarantineInterval: idle time before the maintainer removes a consumer group with no consumers
        "MaintainerQuarantineInterval": "1:00:00",
        // MaintainerSearchPattern: Redis key glob pattern for maintainer scan; null = use default prefix pattern
        "MaintainerSearchPattern": null,
        // ProfilerEnabled: enable per-stream Redis command profiling
        "ProfilerEnabled": false,
        // EmitStreamReceivedEvent: emit a telemetry event for each raw stream message received
        "EmitStreamReceivedEvent": false,
        // NotifyEnabled: opt-in pub/sub doorbell — PUBLISH after XADD wakes consumer immediately instead of waiting PollInterval
        "NotifyEnabled": false,
        // NotifyChannelStrategy: set in code; see how-to/telemetry-and-strategies.md
        // NotifyChannelName: channel suffix appended to the stream key; ignored if NotifyChannelStrategy is set in code
        "NotifyChannelName": "notify",
        // NotifyShardedPubSub: true = use SPUBLISH/SSUBSCRIBE (Redis 7.0+); ignored if NotifyChannelStrategy is set
        "NotifyShardedPubSub": false,
        // NotifySubscriberTimeout: null or non-positive = multiplexer timeout; resubscribe interval when Subscribe fails
        "NotifySubscriberTimeout": null,
        // NotifySubscriberDueTime: null = half of resolved NotifySubscriberTimeout; delay before first subscribe attempt
        "NotifySubscriberDueTime": null,
        // Per-topic overrides. Matched case-insensitively on Name; only present fields override app-wide values (delta overlay).
        // App-wide-only fields (ignored per topic): Enabled, ConnectionMonitorEnabled, TrackStatistics, Maintainer*.
        "Topics": [
          { "Name": "ilist:simplefolder", "MaxLength": 131072, "PollInterval": "0:00:00.050" }
        ]
      },

      // ---- Broadcast.RedisPubSub (UiPath.Caching.Broadcast.Redis.RedisPubSubTopicOptions) ----
      "RedisPubSub": {
        // Enabled: enable/disable the Redis Pub/Sub provider app-wide (per-topic override ignored); default false
        "Enabled": false,
        // RedisChannelStrategy: set in code; see how-to/telemetry-and-strategies.md
        // ConsumerCapacity: bounded-channel capacity for in-process event delivery; -1 for unbounded
        "ConsumerCapacity": 2048,
        // FullMode: BoundedChannelFullMode when channel is full: Wait | DropNewest | DropOldest | DropWrite
        "FullMode": "Wait",
        // SlowObserverThreshold: log warning when an observer takes longer than this to process an event
        "SlowObserverThreshold": "0:00:00.250",
        // ConnectionMonitorEnabled: null = inherit from CacheOptions.ConnectionMonitorEnabled
        "ConnectionMonitorEnabled": null,
        // SubscriberTimeout: null = multiplexer timeout; resubscribe interval when Subscribe fails
        "SubscriberTimeout": null,
        // SubscriberDueTime: null = half of resolved SubscriberTimeout; delay before first subscribe attempt
        "SubscriberDueTime": null,
        // Per-topic overrides. Matched case-insensitively on Name; only present fields override app-wide values (delta overlay).
        "Topics": [
          { "Name": "orders", "SlowObserverThreshold": "0:00:00.100" }
        ]
      }
    },

    // ---- InMemoryRedis (UiPath.Caching.InMemoryRedisCacheOptions) ----
    "InMemoryRedis": {
      // Enabled: enable/disable this cache provider
      "Enabled": true,
      // DefaultExpiration: default TTL when no per-call or per-policy expiration is set
      "DefaultExpiration": "1:00:00",
      // Timeout: max wait for a cache operation before giving up
      "Timeout": "0:00:01",
      // Clock / EntryFactory / CacheKeyStrategy: set in code; see how-to/telemetry-and-strategies.md
      // TrackStatistics: emit hit/miss/eviction counters via telemetry
      "TrackStatistics": true,
      // StatisticsFlushInterval: how often statistics are flushed to telemetry
      "StatisticsFlushInterval": "0:01:00",
      // Topic: topic name for L1 invalidation broadcasts; null = use DefaultTopic
      "Topic": null,
      // TopicKeyStrategy: set in code; see how-to/telemetry-and-strategies.md
      // LocalMaxExpiration: cap on the L1 (in-memory) TTL when L2 is connected; null = no cap
      "LocalMaxExpiration": null,
      // ConnectionMonitorEnabled: null = inherit from CacheOptions.ConnectionMonitorEnabled
      "ConnectionMonitorEnabled": null,
      // CacheNullValues: persist null/empty returns as sentinels to suppress thundering-herd
      "CacheNullValues": false,
      // ConnectionMonitorPeriod: how often the connection monitor probes Redis health
      "ConnectionMonitorPeriod": "0:00:05",
      // SizeLimit: max bytes for the in-memory tier; null = unlimited
      "SizeLimit": null,
      // CompactionPercentage: fraction of SizeLimit to free when the limit is hit; null = runtime default (0.05)
      "CompactionPercentage": null,
      // SizeProvider: set in code; see how-to/telemetry-and-strategies.md
      // UseLocalOnlyWhenDisconnected: null = false; true = serve L1-only when L2 is disconnected
      "UseLocalOnlyWhenDisconnected": null,
      // LocalMaxExpirationDisconnected: L1 TTL cap while L2 is disconnected; limits stale-read window
      "LocalMaxExpirationDisconnected": "0:00:30",
      // LocalLockEnabled: acquire a local (in-process) lock before calling the value factory
      "LocalLockEnabled": true,
      // LocalLockTimeout: max wait to acquire the local lock before bypassing it
      "LocalLockTimeout": "0:00:00.500",
      // DistributedLockEnabled: acquire a distributed (Redis) lock before calling the value factory; null = not configured
      "DistributedLockEnabled": null,
      // DistributedLockTimeout: max wait to acquire the distributed lock
      "DistributedLockTimeout": "0:00:00.500",
      // DistributedLockExpiry: Redis key TTL for the distributed lock (safety expiry)
      "DistributedLockExpiry": "0:00:05"
      // LockKeyStrategy: set in code; see how-to/telemetry-and-strategies.md
    },

    // ---- InMemory (UiPath.Caching.InMemoryCacheOptions) ----
    "InMemory": {
      // Enabled: enable/disable this cache provider
      "Enabled": true,
      // DefaultExpiration: default TTL when no per-call or per-policy expiration is set
      "DefaultExpiration": "1:00:00",
      // Timeout: max wait for a cache operation before giving up
      "Timeout": "0:00:01",
      // Clock / EntryFactory / CacheKeyStrategy: set in code; see how-to/telemetry-and-strategies.md
      // TrackStatistics: emit hit/miss/eviction counters via telemetry
      "TrackStatistics": true,
      // StatisticsFlushInterval: how often statistics are flushed to telemetry
      "StatisticsFlushInterval": "0:01:00",
      // BroadcastEnable: enable broadcast invalidation for this in-memory cache
      "BroadcastEnable": false,
      // Topic: topic name for invalidation broadcasts; null = use DefaultTopic
      "Topic": null,
      // LocalMaxExpiration: cap on in-memory TTL; null = no cap (uses DefaultExpiration)
      "LocalMaxExpiration": "1:00:00",
      // TopicKeyStrategy: set in code; see how-to/telemetry-and-strategies.md
      // ConnectionMonitorEnabled: inert for in-memory provider; present to satisfy IMultilayerCacheOptions
      "ConnectionMonitorEnabled": null,
      // CacheNullValues: persist null/empty returns as sentinels to suppress thundering-herd
      "CacheNullValues": false,
      // ConnectionMonitorPeriod: inert for in-memory provider; present to satisfy IMultilayerCacheOptions
      "ConnectionMonitorPeriod": "0:00:05",
      // SizeLimit: max bytes for the in-memory tier; null = unlimited
      "SizeLimit": null,
      // CompactionPercentage: fraction of SizeLimit to free when the limit is hit; null = runtime default (0.05)
      "CompactionPercentage": null,
      // SizeProvider: set in code; see how-to/telemetry-and-strategies.md
      // UseLocalOnlyWhenDisconnected: inert for in-memory provider; present to satisfy IMultilayerCacheOptions contract
      "UseLocalOnlyWhenDisconnected": null,
      // LocalMaxExpirationDisconnected: inert for in-memory provider; present to satisfy IMultilayerCacheOptions contract
      "LocalMaxExpirationDisconnected": "0:00:30",
      // LocalLockEnabled: acquire a local (in-process) lock before calling the value factory
      "LocalLockEnabled": true,
      // LocalLockTimeout: max wait to acquire the local lock before bypassing it
      "LocalLockTimeout": "0:00:00.500",
      // DistributedLockEnabled: inert for in-memory provider; present to satisfy IMultilayerCacheOptions contract; null = not configured
      "DistributedLockEnabled": null,
      // DistributedLockTimeout: inert for in-memory provider; present to satisfy IMultilayerCacheOptions contract
      "DistributedLockTimeout": null,
      // DistributedLockExpiry: inert for in-memory provider; present to satisfy IMultilayerCacheOptions contract
      "DistributedLockExpiry": null
      // LockKeyStrategy: set in code; see how-to/telemetry-and-strategies.md
    },

    // ---- Redis (UiPath.Caching.Redis.RedisCacheOptions) ----
    "Redis": {
      // Enabled: enable/disable this cache provider
      "Enabled": true,
      // DefaultExpiration: default TTL when no per-call or per-policy expiration is set
      "DefaultExpiration": "1:00:00",
      // KeyPrefix: prefix prepended to every Redis key
      "KeyPrefix": "",
      // Timeout: max wait for a cache operation before giving up
      "Timeout": "0:00:01",
      // Clock / EntryFactory / CacheKeyStrategy / RedisKeyStrategyFactory: set in code; see how-to/telemetry-and-strategies.md
      // ConnectionMonitorEnabled: null = inherit from CacheOptions.ConnectionMonitorEnabled
      "ConnectionMonitorEnabled": null,
      // CacheNullValues: persist null/empty returns as sentinels to suppress thundering-herd
      "CacheNullValues": false
    },

    // ---- ResiliencePolicies (UiPath.Caching.Polly.ResiliencePoliciesOptions) ----
    "ResiliencePolicies": {
      // Enabled: enable Polly circuit-breaker and retry policies for Redis operations
      "Enabled": true,
      // DurationOfBreak: how long the circuit stays open after tripping
      "DurationOfBreak": "0:01:00",
      // ExceptionsAllowedBeforeBreaking: failures within the sampling window before the circuit opens
      "ExceptionsAllowedBeforeBreaking": 500,
      // RequestTimeout: per-operation timeout enforced by the Polly pipeline
      "RequestTimeout": "0:00:01",
      // RetryCount: number of immediate retries before propagating failure
      "RetryCount": 1,
      // TelemetryEnabled: emit circuit-breaker state-change events via telemetry
      "TelemetryEnabled": true,
      // RethrowCircuitBreakerExceptions: true = rethrow BrokenCircuitException instead of swallowing
      "RethrowCircuitBreakerExceptions": false
    },

    // ---- Per-cache policies (UiPath.Caching.CachePolicy) ----
    // Keyed by string. ICache<T>/IHashCache<T> bind a policy by name at construction (default key = typeof(T).FullName).
    // Names not registered fall back to DefaultCachePolicy. Per-call expiration arguments override DistributedExpiration.
    "Policies": {
      "MyApp.Models.Order": {
        // LocalExpiration: L1 cap for this policy; null = inherit from IMultilayerCacheOptions.LocalMaxExpiration (InMemoryRedis or InMemory provider)
        "LocalExpiration": "0:01:00",
        // LocalExpirationDisconnected: L1 cap when L2 disconnected; null = inherit from IMultilayerCacheOptions.LocalMaxExpirationDisconnected
        "LocalExpirationDisconnected": "0:00:30",
        // DistributedExpiration: L2 TTL; null = use provider DefaultExpiration
        "DistributedExpiration": "0:10:00",
        // FactoryTimeout: max time allowed for the value factory before it is abandoned
        "FactoryTimeout": "0:00:02",
        // JitterMaxDuration: max random duration added to L2 TTL at write time; null/zero disables jitter
        "JitterMaxDuration": "0:00:30",
        // RehydrateEnabled: master switch for proactive background refresh; null = inherit (default off)
        "RehydrateEnabled": true,
        // Rehydrate: tuning for proactive background refresh (UiPath.Caching.RehydrateOptions)
        "Rehydrate": {
          // Threshold: soft-TTL trigger fraction in (0, 1]; refresh fires when elapsed >= Threshold * Duration (i.e. 0.75 = refresh after 75% of the TTL has elapsed)
          "Threshold": 0.75,
          // BaseCooldown: minimum cooldown between consecutive refresh attempts
          "BaseCooldown": "0:00:05",
          // MaxCooldown: upper bound on backoff cooldown after repeated failures
          "MaxCooldown": "0:05:00",
          // TimeoutFraction: background factory timeout as a fraction of entry Duration; floored at 1s
          "TimeoutFraction": 0.5,
          // Name: profile label surfaced on telemetry as the 'profile' dimension
          "Name": null
        },
        // Lock: per-cache lock overrides; field-level merged against default policy (UiPath.Caching.LockProfile)
        "Lock": {
          // LocalLockEnabled: null = inherit from provider options or default policy
          "LocalLockEnabled": true,
          // DistributedLockEnabled: null = inherit from provider options or default policy
          "DistributedLockEnabled": false,
          // LocalLockTimeout: null = inherit from provider options or default policy
          "LocalLockTimeout": "0:00:00.500",
          // DistributedLockTimeout: null = inherit from provider options or default policy
          "DistributedLockTimeout": "0:00:00.500",
          // DistributedLockExpiry: null = inherit from provider options or default policy
          "DistributedLockExpiry": "0:00:05"
        }
      }
    },

    // ---- DefaultCachePolicy (UiPath.Caching.CachePolicy) ----
    // Fallback policy when a cache instance name is not in Policies. null = library default (CachePolicy.Empty).
    "DefaultCachePolicy": null
  },
  "AllowedHosts": "*"
}
